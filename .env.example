# ─── Portfolio — Umgebungsvariablen ─────────────────────────────────────────
# Produktion: /etc/portfolio/portfolio.env (root:portfolio, 640).
# systemd-EnvironmentFile expandiert '$' NICHT — Argon2-Hashes sind literal sicher.
# Lokal: Werte in .env.local (gitignored).

# Öffentliche Basis-URL der Site (für metadataBase / OG-Link-Previews).
# Lokal/Dev optional (Fallback https://example.com); in Produktion echte URL setzen.
NEXT_PUBLIC_SITE_URL=https://example.com

# Ladungsfähige Anschrift fürs Impressum (§ 5 DDG), '|'-getrennte Zeilen.
# BEWUSST nicht im Repo — nur hier/Server, damit die Privatadresse nicht in die
# (öffentliche) git-History gerät. Wird zur BUILD-Zeit gelesen (static prerender);
# deploy-vps.sh sourct dafür /etc/portfolio/portfolio.env vor dem Build.
# Leer lassen → Impressum bleibt auf Platzhalter, Footer blendet Rechts-Links aus.
#   LEGAL_ADDRESS_LINES=Musterstr. 1|12345 Musterstadt
LEGAL_ADDRESS_LINES=

# Session-Signatur (HS256). Mind. 32 Zeichen, zufällig.
# Erzeugen:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Benannte Zugangscodes: name1:$argon2id$...;name2:$argon2id$...
# Erzeugen:  node scripts/hash-code.mjs --gen itfabrik
# ⚠ WICHTIG in Next-eigenen .env-Dateien (.env.local etc.): alle '$' als '\$'
#   escapen — dotenv-expand expandiert sonst $argon2id/$v/$m und zerstört den
#   Hash. systemd-EnvironmentFile (Produktion) expandiert NICHT → dort literal.
ACCESS_CODES=

# Zugriffs-Log (JSONL). Leer lassen = Logging aus.
# Produktion: /opt/portfolio/logs/access.jsonl
ACCESS_LOG_PATH=

# Phase 6 (Stretch): Ollama-Chat-Demo
CHAT_ENABLED=false
OLLAMA_DEMO_MODEL=
